# ─── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.luvira-guardian
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_MGMT_API_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
LOG_LEVEL=INFO

# ─── External API base URLs ───────────────────────────────────────────────────
GITLAB_BASE_URL=https://gitlab.com/api/v4
SLACK_API_BASE_URL=https://slack.com/api
GOOGLE_API_BASE_URL=https://www.googleapis.com

# ─── Demo defaults (optional) ─────────────────────────────────────────────────
DEMO_DEFAULT_GITLAB_PROJECT_ID=
DEMO_DEFAULT_GITLAB_ISSUE_IID=
DEMO_DEFAULT_SLACK_CHANNEL=
DEMO_DEFAULT_CALENDAR_ID=primary
